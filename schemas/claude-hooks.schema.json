{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MDT Claude Hook Configuration",
  "description": "Schema for the Claude-style hook config shipped in hooks/claude/hooks.json and mirrored to hooks/hooks.json.",
  "$defs": {
    "eventName": {
      "type": "string",
      "enum": [
        "PreToolUse",
        "PostToolUse",
        "PreCompact",
        "SessionStart",
        "SessionEnd",
        "Stop",
        "Notification",
        "SubagentStop"
      ]
    },
    "commandHook": {
      "type": "object",
      "required": [
        "type",
        "command"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "command",
          "description": "Claude hook entries in this repo are command hooks."
        },
        "command": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            }
          ]
        },
        "async": {
          "type": "boolean",
          "description": "Run hook asynchronously in background without blocking"
        },
        "timeout": {
          "type": "number",
          "minimum": 0,
          "description": "Timeout in seconds for async hooks"
        }
      }
    },
    "matcherEntry": {
      "type": "object",
      "required": [
        "matcher",
        "hooks"
      ],
      "properties": {
        "matcher": {
          "type": "string"
        },
        "hooks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/commandHook"
          }
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "$schema": {
          "type": "string"
        },
        "hooks": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/eventName"
          },
          "additionalProperties": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/matcherEntry"
            }
          }
        }
      },
      "required": [
        "hooks"
      ]
    },
    {
      "type": "array",
      "items": {
        "$ref": "#/$defs/matcherEntry"
      }
    }
  ]
}
