{
  "name": "modeldev-toolkit",
  "version": "1.7.0",
  "description": "Generic model toolkit for software development workflows: agents, skills, hooks, commands, and scaffolding across Claude Code, Cursor, Codex, and Gemini",
  "keywords": [
    "model-toolkit",
    "llm-toolkit",
    "software-development",
    "ai",
    "agents",
    "skills",
    "hooks",
    "mcp",
    "rules",
    "llm",
    "modelops",
    "tdd",
    "code-review",
    "security",
    "automation",
    "best-practices",
    "cursor",
    "cursor-ide",
    "opencode",
    "codex",
    "presentations",
    "slides"
  ],
  "author": {
    "name": "Affaan Mustafa",
    "url": "https://x.com/affaanmustafa"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flatrick/everything-claude-code.git"
  },
  "homepage": "https://github.com/flatrick/everything-claude-code#readme",
  "bugs": {
    "url": "https://github.com/flatrick/everything-claude-code/issues"
  },
  "files": [
    ".agent/",
    ".gemini/",
    ".agents/",
    ".codex/",
    ".cursor/",
    ".opencode/commands/",
    ".opencode/instructions/",
    ".opencode/plugins/",
    ".opencode/prompts/",
    ".opencode/tools/",
    ".opencode/index.ts",
    ".opencode/opencode.json",
    ".opencode/package.json",
    ".opencode/tsconfig.json",
    ".opencode/MIGRATION.md",
    ".opencode/README.md",
    "agents/",
    "commands/",
    "contexts/",
    "examples/CLAUDE.md",
    "examples/user-CLAUDE.md",
    "examples/statusline.json",
    "hooks/",
    "mcp-configs/",
    "plugins/",
    "rules/",
    "schemas/",
    "scripts/ci/",
    "scripts/hooks/",
    "scripts/lib/",
    "scripts/claw.js",
    "scripts/setup-package-manager.js",
    "scripts/skill-create-output.js",
    "skills/",
    "AGENTS.md",
    ".claude-plugin/plugin.json",
    ".claude-plugin/README.md",
    "scripts/install-mdt.js"
  ],
  "bin": {
    "mdt-install": "scripts/install-mdt.js"
  },
  "scripts": {
    "postinstall": "echo '\\n  modeldev-toolkit installed!\\n  Run: npx mdt-install typescript\\n  Docs: https://github.com/flatrick/everything-claude-code\\n'",
    "install-mdt": "node scripts/install-mdt.js",
    "release": "node scripts/release.js",
    "lint": "node scripts/ci/check-dependencies.js eslint markdownlint-cli && eslint . && markdownlint \"**/*.md\" --ignore node_modules",
    "claw": "node scripts/claw.js",
    "test": "node scripts/ci/check-dependencies.js eslint markdownlint-cli && node scripts/ci/validate-agents.js && node scripts/ci/validate-commands.js && node scripts/ci/validate-rules.js && node scripts/ci/validate-skills.js && node scripts/ci/validate-hooks.js && node scripts/ci/validate-no-hardcoded-paths.js && node tests/run-all.js",
    "test:neutral": "node tests/run-all.js --profile neutral",
    "test:claude": "node tests/run-all.js --profile claude",
    "test:cursor": "node tests/run-all.js --profile cursor",
    "test:codex": "node tests/run-all.js --profile codex",
    "test:gemini": "node tests/run-all.js --profile gemini"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "globals": "^17.1.0",
    "markdownlint-cli": "^0.47.0"
  },
  "engines": {
    "node": ">=18"
  }
}
