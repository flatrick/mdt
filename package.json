{
  "name": "modeldev-toolkit",
  "version": "1.7.0",
  "description": "ModelDev Toolkit (MDT) is a Node-only workflow toolkit with agents, skills, hooks, commands, and scaffolding for Claude Code, Cursor, Codex, Gemini, and OpenCode",
  "keywords": [
    "model-toolkit",
    "llm-toolkit",
    "software-development",
    "ai",
    "agents",
    "skills",
    "hooks",
    "mcp",
    "rules",
    "llm",
    "modelops",
    "tdd",
    "code-review",
    "security",
    "automation",
    "best-practices",
    "cursor",
    "cursor-ide",
    "opencode",
    "codex",
    "presentations",
    "slides"
  ],
  "author": {
    "name": "flatrick",
    "url": "https://github.com/flatrick"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flatrick/modeldev-toolkit.git"
  },
  "homepage": "https://github.com/flatrick/modeldev-toolkit#readme",
  "bugs": {
    "url": "https://github.com/flatrick/modeldev-toolkit/issues"
  },
  "files": [
    ".agent/",
    ".gemini/",
    ".agents/",
    "claude-template/",
    "codex-template/",
    "cursor-template/",
    "opencode-template/commands/",
    "opencode-template/instructions/",
    "opencode-template/plugins/",
    "opencode-template/prompts/",
    "opencode-template/tools/",
    "opencode-template/index.ts",
    "opencode-template/opencode.json",
    "opencode-template/package.json",
    "opencode-template/tsconfig.json",
    "opencode-template/MIGRATION.md",
    "opencode-template/README.md",
    "agents/",
    "commands/",
    "contexts/",
    "examples/CLAUDE.md",
    "examples/user-CLAUDE.md",
    "examples/statusline.json",
    "hooks/",
    "mcp-configs/",
    "plugins/",
    "rules/",
    "schemas/",
    "scripts/ci/",
    "scripts/hooks/",
    "scripts/lib/",
    "scripts/claw.js",
    "scripts/setup-package-manager.js",
    "scripts/skill-create-output.js",
    "skills/",
    "AGENTS.md",
    ".claude-plugin/plugin.json",
    ".claude-plugin/README.md",
    "scripts/install-mdt.js"
  ],
  "bin": {
    "mdt-install": "scripts/install-mdt.js"
  },
  "scripts": {
    "postinstall": "echo '\\n  modeldev-toolkit installed!\\n  Run: npx mdt-install typescript\\n  Docs: https://github.com/flatrick/modeldev-toolkit\\n'",
    "install-mdt": "node scripts/install-mdt.js",
    "sync:hook-mirrors": "node scripts/sync-hook-mirrors.js",
    "release": "node scripts/release.js",
    "lint": "node scripts/ci/check-dependencies.js eslint markdownlint-cli && eslint . && markdownlint \"**/*.md\" --ignore node_modules",
    "claw": "node scripts/claw.js",
    "test": "node scripts/ci/check-dependencies.js eslint markdownlint-cli && node scripts/ci/validate-agents.js && node scripts/ci/validate-commands.js && node scripts/ci/validate-rules.js && node scripts/ci/validate-skills.js && node scripts/ci/validate-hooks.js && node scripts/ci/validate-metadata.js && node scripts/ci/validate-no-hardcoded-paths.js && node scripts/ci/validate-markdown-links.js && node scripts/ci/validate-markdown-path-refs.js && node scripts/verify-tool-setups.js && node tests/run-all.js",
    "test:neutral": "node tests/run-all.js --profile neutral",
    "test:claude": "node tests/run-all.js --profile claude",
    "test:cursor": "node tests/run-all.js --profile cursor",
    "test:codex": "node tests/run-all.js --profile codex",
    "test:gemini": "node tests/run-all.js --profile gemini",
    "verify:tool-setups": "node scripts/verify-tool-setups.js",
    "smoke:tool-setups": "node scripts/smoke-tool-setups.js",
    "smoke:codex-workflows": "node scripts/smoke-codex-workflows.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "globals": "^17.1.0",
    "markdownlint-cli": "^0.47.0"
  },
  "engines": {
    "node": ">=18"
  }
}
